# Shared
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_WWW_URL=http://localhost:3000
API_URL=http://localhost:4000
# Browser-exposed API base for the chat app (guest session, etc.)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Auth
# Signs guest session cookies and backend app session (fc_user) tokens.
AUTH_SECRET=replace-me
# Real Google OAuth credentials. Leave unset locally to use the dev-mock login.
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
# Dev-only: when "true", the API accepts mock Google tokens and the app shows a
# "test account" login button so Google login is demoable without real OAuth.
# Never enable in production.
AUTH_DEV_MODE=true
NEXT_PUBLIC_AUTH_DEV_MODE=true

# Services
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fahhhchat
REDIS_URL=redis://localhost:6379

# Feature flags / launch kill switches
# Comma-separated flag keys to start *disabled* at boot, for killing a risky
# surface without an admin UI. Valid keys: camera_media, gender_filters,
# guest_access, queue_entry. Leave unset to start every surface enabled.
FEATURE_FLAGS_DISABLED=

# Admin/bootstrap
ADMIN_EMAIL_ALLOWLIST=founder@example.com
